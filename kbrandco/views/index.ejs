<!-- ═══════════════════════════════════════════════════════ ABOUT / HERITAGE -->
<section class="section" id="about">
  <div class="container">
    <div class="section-label">Our Heritage</div>
    <h2 class="section-title">Three Decades of Service</h2>
    <p class="section-sub">Founded on July 2, 1991, KBR &amp; Co. is a Chartered Accountancy firm serving diverse clients across industries with dedication and professional competence.</p>

    <div class="grid-4 reveal-group">
      <div class="heritage-card reveal">
        <div class="hc-year">1991</div>
        <h3>Founded</h3>
        <p>Established with a vision to deliver professional services grounded in integrity, technical competence, and client service. Headquartered in Chennai with a branch in Palani.</p>
      </div>
      <div class="heritage-card reveal">
        <div class="hc-year">30+</div>
        <h3>Years of Experience</h3>
        <p>Across diverse industries — hospitality, retail, pharmaceuticals, logistics, and emerging startups. Deep expertise in complex GST compliance.</p>
      </div>
      <div class="heritage-card reveal">
        <div class="hc-year">TN</div>
        <h3>Tamil Nadu Presence</h3>
        <p>Serving corporations, SMEs, charitable trusts, and professional associations across Tamil Nadu from our Chennai and Palani offices.</p>
      </div>
      <div class="heritage-card reveal">
        <div class="hc-year">II</div>
        <h3>Second Generation</h3>
        <p>Built on a legacy of professional practice, ethical conduct, and commitment to client confidentiality and service excellence.</p>
      </div>
    </div>

    <!-- Vision & Mission -->
    <div class="vm-grid reveal-group" style="margin-top:3rem;">
      <div class="vm-card reveal">
        <div class="vm-icon">◈</div>
        <h3>Vision</h3>
        <p>To build a multi-branch Chartered Accountancy practice across South India, recognised for deep expertise in fundraising advisory and tax litigation support — helping businesses navigate complex financial and regulatory challenges with confidence.</p>
      </div>
      <div class="vm-card reveal">
        <div class="vm-icon">◉</div>
        <h3>Mission</h3>
        <p>We believe compliance is the foundation of sustainable business growth — not a checkbox exercise. Our mission is to deliver practical, value-driven professional services that ensure statutory compliance, provide strategic advisory on fundraising and tax matters, and build enduring partnerships based on trust and measurable results.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════ SERVICES -->
<section class="section section-alt" id="services">
  <div class="container">
    <div class="section-label">What We Do</div>
    <h2 class="section-title">Our Services</h2>
    <p class="section-sub">Specialised in GST compliance for retail and hospitality businesses, direct taxation, statutory audits, and strategic advisory including fundraising and M&amp;A support.</p>

    <div class="grid-3 reveal-group">

      <div class="service-card reveal">
        <div class="sc-number">01</div>
        <h3>GST Compliance &amp; Advisory</h3>
        <p class="sc-tag">Specialists in GST for retail and hospitality</p>
        <ul>
          <li>GSTR-1 Filing and Compliance</li>
          <li>GSTR-2B vs Books Reconciliation</li>
          <li>GST Payment Approval &amp; GSTR-3B</li>
          <li>GST Annual Returns and Audits</li>
          <li>GST Notice Handling and Adjudications</li>
          <li>GST Litigation Support and Representation</li>
        </ul>
      </div>

      <div class="service-card reveal">
        <div class="sc-number">02</div>
        <h3>TDS &amp; Direct Tax</h3>
        <p class="sc-tag">End-to-end tax compliance and advisory</p>
        <ul>
          <li>TDS Payment and Processing</li>
          <li>Quarterly TDS Statements</li>
          <li>TDS Rectifications and Revisions</li>
          <li>TRACES Notice Handling</li>
          <li>Income Tax Return Filing</li>
          <li>Tax Audits under Section 44AB</li>
          <li>15CB Certification and 15CA Filings</li>
          <li>Cross-border Tax Opinions</li>
        </ul>
      </div>

      <div class="service-card reveal">
        <div class="sc-number">03</div>
        <h3>Audit &amp; Assurance</h3>
        <p class="sc-tag">Independent, rigorous, and value-adding</p>
        <ul>
          <li>Statutory Audits for Companies and LLPs</li>
          <li>Internal Audits for Hospitality and Retail</li>
          <li>Concurrent Audits</li>
          <li>Standard Operating Procedures (SOPs)</li>
          <li>Process Mapping and Documentation</li>
        </ul>
      </div>

      <div class="service-card featured reveal">
        <div class="sc-number">04</div>
        <h3>Fundraising &amp; M&amp;A</h3>
        <p class="sc-tag">Complex transactions, multi-disciplinary expertise</p>
        <ul>
          <li>Debt Syndication and Fund Placement</li>
          <li>Equity Fundraising Support</li>
          <li>Merger &amp; Acquisition Advisory</li>
          <li>Transaction Structuring</li>
          <li>Financial Due Diligence</li>
          <li>Coordination with Legal and Valuation Experts</li>
        </ul>
      </div>

      <div class="service-card reveal">
        <div class="sc-number">05</div>
        <h3>Accounting &amp; CFO Services</h3>
        <p class="sc-tag">Operational financial leadership for SMEs</p>
        <ul>
          <li>Outsourced Accounting Services</li>
          <li>Financial Projections and Modelling</li>
          <li>Virtual CFO Services for SMEs</li>
          <li>Chart of Accounts Design</li>
          <li>ERP Migration Support</li>
        </ul>
      </div>

      <div class="service-card reveal">
        <div class="sc-number">06</div>
        <h3>Corporate Compliance</h3>
        <p class="sc-tag">Company law, ROC, and governance</p>
        <ul>
          <li>Company Incorporations</li>
          <li>ROC Annual Filings</li>
          <li>Board Resolution Management</li>
          <li>Statutory Compliance Support</li>
          <li>Corporate Governance Advisory</li>
        </ul>
      </div>

    </div>
  </div>
</section>

