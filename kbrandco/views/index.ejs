    <div class="section-label">Quick Access</div>
    <h2 class="section-title">Essential Resources &amp; Links</h2>
    <p class="section-sub">Direct access to important government portals and regulatory authorities.</p>

    <div class="resources-grid reveal-group">
      <a href="https://www.incometax.gov.in" target="_blank" rel="noopener" class="resource-link reveal">
        <div class="rl-title">Income Tax Department</div>
        <div class="rl-desc">Official portal for income tax filing, returns, and tax-related services</div>
        <div class="rl-domain">incometax.gov.in ↗</div>
      </a>
      <a href="https://www.gst.gov.in" target="_blank" rel="noopener" class="resource-link reveal">
        <div class="rl-title">GST Portal</div>
        <div class="rl-desc">Goods and Services Tax — registration, returns, and compliance</div>
        <div class="rl-domain">gst.gov.in ↗</div>
      </a>
      <a href="https://www.mca.gov.in" target="_blank" rel="noopener" class="resource-link reveal">
        <div class="rl-title">Ministry of Corporate Affairs</div>
        <div class="rl-desc">Corporate registration, compliance, and company-related services</div>
        <div class="rl-domain">mca.gov.in ↗</div>
      </a>
      <a href="https://www.rbi.org.in" target="_blank" rel="noopener" class="resource-link reveal">
        <div class="rl-title">Reserve Bank of India</div>
        <div class="rl-desc">Central banking, monetary policy, and financial regulations</div>
        <div class="rl-domain">rbi.org.in ↗</div>
      </a>
      <a href="https://www.sebi.gov.in" target="_blank" rel="noopener" class="resource-link reveal">
        <div class="rl-title">SEBI</div>
        <div class="rl-desc">Securities and Exchange Board of India — capital markets regulation</div>
        <div class="rl-domain">sebi.gov.in ↗</div>
      </a>
      <a href="https://www.icai.org" target="_blank" rel="noopener" class="resource-link reveal">
        <div class="rl-title">ICAI</div>
        <div class="rl-desc">Institute of Chartered Accountants of India — professional standards</div>
        <div class="rl-domain">icai.org ↗</div>
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════ CAREERS -->
<section class="section section-alt" id="careers">
  <div class="container">
    <div class="section-label">Join Our Team</div>
    <h2 class="section-title">Grow With Us</h2>
    <p class="section-sub">We are expanding our practice with new assignments in M&amp;A, fundraising, and tax litigation. If you are looking for meaningful work and real responsibility, we would like to hear from you.</p>

    <div class="form-wrap reveal">
      <form id="careersForm" class="kbr-form" novalidate>
        <div class="form-row">
          <div class="form-group">
            <label for="c-name">Full Name *</label>
            <input type="text" id="c-name" name="name" placeholder="Your name" required>
          </div>
          <div class="form-group">
            <label for="c-email">Email Address *</label>
            <input type="email" id="c-email" name="email" placeholder="you@example.com" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="c-phone">Phone Number</label>
            <input type="tel" id="c-phone" name="phone" placeholder="+91 98765 43210">
          </div>
          <div class="form-group">
            <label for="c-position">Position Applying For *</label>
            <select id="c-position" name="position" required>
              <option value="" disabled selected>— Select Position —</option>
              <option value="Articled Assistant">Articled Assistant</option>
              <option value="Paid Assistant">Paid Assistant</option>
              <option value="Manager">Manager</option>
              <option value="Subject Matter Expert">Subject Matter Expert</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="c-expertise">Subject Matter Expertise</label>
          <input type="text" id="c-expertise" name="expertise" placeholder="e.g. GST, Direct Tax, Audit, Investment Banking">
        </div>
        <div class="form-group">
          <label for="c-additional">Additional Information</label>
          <textarea id="c-additional" name="additional" rows="4" placeholder="Tell us about yourself, your experience, and why you want to join KBR & Co."></textarea>
        </div>
        <div class="form-msg" id="careerMsg"></div>
        <button type="submit" class="btn btn-primary">Submit Application</button>
      </form>
    </div>
  </div>
</section>

