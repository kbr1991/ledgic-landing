<!-- ═══════════════════════════════════════════════════════ HERO -->
<section class="hero" id="home">
  <div class="hero-bg-grid"></div>
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Since 1991 &nbsp;·&nbsp; ICAI Registered &nbsp;·&nbsp; Chennai & Palani
      </div>
      <h1 class="hero-title">
        Professional<br>
        <em>Chartered Accountancy</em><br>
        Services
      </h1>
      <p class="hero-sub">
        KBR &amp; Co. is a Chennai-based CA firm with over three decades of experience in GST compliance, direct taxation, statutory audits, and strategic advisory. We serve SMEs, corporations, trusts, and associations across Tamil Nadu.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Get in Touch</a>
        <a href="#services" class="btn btn-outline">Our Services</a>
