          <span class="stat-label">Years of Practice</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">20+</span>
          <span class="stat-label">Professionals</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">2</span>
          <span class="stat-label">Offices — Chennai & Palani</span>
        </div>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <div class="hero-card-stack">
        <div class="hcard hcard-1">
          <span class="hcard-label">Practice Areas</span>
          <div class="hcard-items">
