<!-- ═══════════════════════════════════════════════════════ BLOG -->
<section class="section section-alt" id="blog">
  <div class="container">
    <div class="section-label">Insights &amp; Updates</div>
    <h2 class="section-title">KBR &amp; Co. Blog</h2>
    <p class="section-sub">Expert analysis, regulatory updates, and practical insights on taxation, compliance, and business advisory.</p>

    <% if (posts && posts.length > 0) { %>
    <div class="grid-3 reveal-group">
      <% posts.forEach((post, i) => { %>
      <a href="/blog/<%= post.slug %>" class="blog-card reveal">
        <% if (i === 0) { %><div class="blog-badge">Latest</div><% } %>
        <div class="blog-meta">
          <span><%= new Date(post.created_at).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></span>
          <span><%= post.read_time %> min read</span>
        </div>
        <h3><%= post.title %></h3>
        <p><%= post.excerpt %></p>
        <% if (post.tags) { %>
        <div class="blog-tags">
          <% post.tags.split(',').slice(0,3).forEach(tag => { %>
          <span class="blog-tag"><%= tag.trim() %></span>
          <% }) %>
        </div>
        <% } %>
        <div class="blog-read-more">Read Analysis →</div>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <p style="text-align:center;color:var(--muted);">Blog posts coming soon.</p>
    <% } %>

    <div style="text-align:center;margin-top:2.5rem;">
      <a href="/blog" class="btn btn-outline">View All Posts</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════ RESOURCES -->
