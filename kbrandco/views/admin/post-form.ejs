<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — KBR Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <meta name="robots" content="noindex">
</head>
<body class="admin-body">
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { active: 'posts' }) %>
  <main class="admin-main">
    <div class="admin-page-header">
      <h1><%= post && post.id ? 'Edit Post' : 'New Post' %></h1>
      <a href="/admin/posts" class="btn btn-outline" style="font-size:0.9rem;padding:0.5rem 1.2rem;">← Back</a>
    </div>
    <% if (error) { %><div class="admin-alert error"><%= error %></div><% } %>
    <form method="POST" action="<%= post && post.id ? '/admin/posts/'+post.id+'/edit' : '/admin/posts/new' %>" class="admin-post-form">
      <div class="form-group">
        <label>Title *</label>
        <input type="text" name="title" value="<%= post ? post.title || '' : '' %>" required placeholder="Post title">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Tags <small>(comma-separated)</small></label>
          <input type="text" name="tags" value="<%= post ? post.tags || '' : '' %>" placeholder="GST, Income Tax, Budget">
        </div>
        <div class="form-group">
          <label>Read Time (minutes)</label>
          <input type="number" name="read_time" value="<%= post ? post.read_time || 5 : 5 %>" min="1" max="60">
        </div>
      </div>
      <div class="form-group">
        <label>Excerpt <small>(shown in listings)</small></label>
        <textarea name="excerpt" rows="2" placeholder="Brief summary of the post"><%= post ? post.excerpt || '' : '' %></textarea>
      </div>
      <div class="form-group">
        <label>Content * <small>(Markdown supported)</small></label>
        <textarea name="content" rows="20" required placeholder="Write your post in Markdown..."><%= post ? post.content || '' : '' %></textarea>
      </div>
      <div class="form-group admin-checkbox">
        <label>
          <input type="checkbox" name="published" <%= (post && post.published) ? 'checked' : '' %>>
          <span>Publish this post (make it visible on the website)</span>
        </label>
      </div>
      <div style="display:flex;gap:1rem;">
        <button type="submit" class="btn btn-primary"><%= post && post.id ? 'Save Changes' : 'Create Post' %></button>
        <a href="/admin/posts" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </main>
</div>
</body>
</html>
