<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #020817; color: #F1F5F9; min-height: 100vh; display: flex; }
    :root {
      --bg: #020817; --bg2: #0A0F1E; --bg3: #0F1629;
      --border: rgba(255,255,255,0.08); --gold: #C9A84C;
      --text1: #F1F5F9; --text2: #94A3B8; --text3: #64748B;
      --green: #10B981; --red: #EF4444; --yellow: #F59E0B;
    }

    /* Sidebar */
    .sidebar { width: 240px; min-height: 100vh; background: var(--bg2); border-right: 1px solid var(--border); padding: 24px 0; flex-shrink: 0; position: sticky; top: 0; }
    .sidebar-logo { padding: 0 20px 24px; border-bottom: 1px solid var(--border); margin-bottom: 20px; }
    .sidebar-logo .lm { font-size: 1.4rem; font-weight: 700; color: var(--gold); }
    .sidebar-logo .ls { display: block; font-size: 0.72rem; color: var(--text3); margin-top: 2px; letter-spacing: 0.05em; text-transform: uppercase; }
    .nav-section { padding: 0 12px; margin-bottom: 8px; }
    .nav-section-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text3); padding: 8px 8px 4px; }
    .nav-item { display: flex; align-items: center; gap: 8px; padding: 9px 12px; border-radius: 8px; color: var(--text2); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: all 0.15s; }
    .nav-item:hover, .nav-item.active { background: rgba(201,168,76,0.1); color: var(--gold); }
    .nav-badge { margin-left: auto; background: var(--red); color: #fff; border-radius: 9999px; padding: 1px 7px; font-size: 0.7rem; font-weight: 700; }
    .sidebar-footer { padding: 20px 20px 0; border-top: 1px solid var(--border); margin-top: auto; }
    .sidebar-user { font-size: 0.8rem; color: var(--text3); margin-bottom: 12px; }
    .sidebar-user strong { color: var(--text2); }
    .btn-logout { display: block; text-align: center; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: #FCA5A5; border-radius: 8px; padding: 8px; font-size: 0.8rem; text-decoration: none; transition: all 0.15s; }
    .btn-logout:hover { background: rgba(239,68,68,0.2); }

    /* Main */
    .main { flex: 1; padding: 32px; overflow-x: auto; }
    .page-header { margin-bottom: 28px; }
    .page-header h1 { font-size: 1.5rem; font-weight: 700; }
    .page-header p { color: var(--text2); font-size: 0.875rem; margin-top: 4px; }

    /* Stats */
    .stats-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }
    .stat-card .s-num { font-size: 2rem; font-weight: 700; color: var(--gold); }
    .stat-card .s-label { font-size: 0.8rem; color: var(--text2); margin-top: 4px; }
    .stat-card.has-unread { border-color: rgba(239,68,68,0.3); }

    /* Table */
    .table-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin-bottom: 28px; }
    .table-card-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; border-bottom: 1px solid var(--border); }
    .table-card-header h3 { font-size: 1rem; font-weight: 600; }
    table { width: 100%; border-collapse: collapse; }
    th { padding: 12px 16px; text-align: left; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text3); background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--border); font-weight: 600; }
    td { padding: 12px 16px; font-size: 0.875rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,0.02); }

    /* Badges */
    .badge { display: inline-block; padding: 3px 9px; border-radius: 9999px; font-size: 0.72rem; font-weight: 600; }
    .badge-green { background: rgba(16,185,129,0.15); color: #6EE7B7; }
    .badge-red { background: rgba(239,68,68,0.15); color: #FCA5A5; }
    .badge-yellow { background: rgba(245,158,11,0.15); color: #FCD34D; }

    /* Buttons */
    .btn { display: inline-block; padding: 8px 16px; border-radius: 8px; font-size: 0.825rem; font-weight: 600; cursor: pointer; border: none; font-family: inherit; text-decoration: none; transition: all 0.15s; }
    .btn-gold { background: var(--gold); color: #020817; }
    .btn-gold:hover { background: #E4C870; }
    .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text2); }
    .btn-outline:hover { border-color: var(--gold); color: var(--gold); }
    .btn-danger { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: #FCA5A5; }
    .btn-danger:hover { background: rgba(239,68,68,0.2); }
    .btn-sm { padding: 5px 12px; font-size: 0.775rem; }

    /* Form */
    .form-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 12px; padding: 28px; }
    .form-group { margin-bottom: 20px; }
    label { display: block; font-size: 0.825rem; font-weight: 500; color: var(--text2); margin-bottom: 6px; }
    input[type=text], input[type=email], input[type=url], input[type=number], select, textarea {
      width: 100%; background: var(--bg2); border: 1px solid var(--border); border-radius: 8px;
      padding: 10px 14px; color: var(--text1); font-size: 0.875rem; font-family: inherit; outline: none;
      transition: border-color 0.2s;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--gold); }
    textarea { resize: vertical; font-family: 'Courier New', monospace; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .checkbox-row { display: flex; align-items: center; gap: 10px; }
    .checkbox-row input[type=checkbox] { width: auto; accent-color: var(--gold); }

    /* Misc */
    .actions { display: flex; gap: 8px; align-items: center; }
    .empty { text-align: center; padding: 40px; color: var(--text3); }
    a { color: inherit; }
    .text-muted { color: var(--text3); font-size: 0.8rem; }
    .view-link { color: var(--gold); font-size: 0.8rem; text-decoration: none; }
    .view-link:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <nav class="sidebar">
    <div class="sidebar-logo">
      <span class="lm">KBR Admin</span>
      <span class="ls">kbrandco.com</span>
    </div>

    <div class="nav-section">
      <div class="nav-section-label">Overview</div>
      <a href="/admin/dashboard" class="nav-item <%= locals.activePage === 'dashboard' ? 'active' : '' %>">📊 Dashboard</a>
    </div>

    <div class="nav-section">
      <div class="nav-section-label">Content</div>
      <a href="/admin/blog" class="nav-item <%= locals.activePage === 'blog' ? 'active' : '' %>">✍️ Blog Posts</a>
    </div>

    <div class="nav-section">
      <div class="nav-section-label">Inbox</div>
      <a href="/admin/contacts" class="nav-item <%= locals.activePage === 'contacts' ? 'active' : '' %>">
        📩 Contact Forms
        <% if (locals.stats && parseInt(stats.unreadContacts) > 0) { %>
        <span class="nav-badge"><%= stats.unreadContacts %></span>
        <% } %>
      </a>
      <a href="/admin/careers" class="nav-item <%= locals.activePage === 'careers' ? 'active' : '' %>">
        💼 Applications
        <% if (locals.stats && parseInt(stats.unreadCareers) > 0) { %>
        <span class="nav-badge"><%= stats.unreadCareers %></span>
        <% } %>
      </a>
    </div>

    <div class="nav-section" style="margin-top:auto">
      <a href="/" target="_blank" rel="noopener" class="nav-item">🌐 View Website</a>
    </div>

    <div class="sidebar-footer">
      <div class="sidebar-user">Logged in as <strong><%= adminUser %></strong></div>
      <a href="/admin/logout" class="btn-logout">Sign Out</a>
    </div>
  </nav>

  <main class="main">
