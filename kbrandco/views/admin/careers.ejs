<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — KBR Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <meta name="robots" content="noindex">
</head>
<body class="admin-body">
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { active: 'careers' }) %>
  <main class="admin-main">
    <div class="admin-page-header"><h1>Career Applications</h1></div>
    <% if (applications.length > 0) { %>
    <table class="admin-table">
      <thead><tr><th>Name</th><th>Email</th><th>Position</th><th>Expertise</th><th>Date</th><th></th></tr></thead>
      <tbody>
        <% applications.forEach(a => { %>
        <tr>
          <td><strong><%= a.name %></strong><% if(a.phone){%><br><small><%= a.phone %></small><%}%></td>
          <td><a href="mailto:<%= a.email %>"><%= a.email %></a></td>
          <td><%= a.position %></td>
          <td><%= a.expertise || '—' %></td>
          <td><%= new Date(a.created_at).toLocaleDateString('en-IN') %></td>
          <td>
            <form method="POST" action="/admin/careers/<%= a.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this application?')">
              <button type="submit" class="aa-del">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } else { %><div class="admin-empty">No applications received yet.</div><% } %>
  </main>
</div>
</body>
</html>
