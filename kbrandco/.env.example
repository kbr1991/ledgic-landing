# Server
PORT=3000
NODE_ENV=production
SESSION_SECRET=replace_with_long_random_string_min_32_chars

# PostgreSQL (Railway auto-injects DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/kbrandco

# Admin Panel Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password

# Zoho Mail – Nodemailer
ZOHO_HOST=smtp.zoho.in
ZOHO_PORT=465
ZOHO_SECURE=true
ZOHO_USER=admin@kbrandco.com
ZOHO_PASS=your_zoho_app_password

# Notification email (who receives form submissions)
NOTIFY_EMAIL=admin@kbrandco.com
